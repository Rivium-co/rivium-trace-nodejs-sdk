{
  "name": "@rivium-trace/nodejs-sdk",
  "version": "0.1.0",
  "description": "RiviumTrace Node.js SDK for server-side error tracking and monitoring",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "lib/**/*.js",
    "index.d.ts",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "example:basic": "node examples/basic-usage.js",
    "example:express": "node examples/express-integration.js",
    "example:database": "node examples/database-example.js",
    "prepublishOnly": "npm test && npm run lint",
    "docs": "jsdoc -d docs lib/ index.js"
  },
  "keywords": [
    "error-tracking",
    "error-monitoring",
    "crash-reporting",
    "exception-handling",
    "logging",
    "debugging",
    "nodejs",
    "rivium-trace",
    "monitoring",
    "observability",
    "express",
    "middleware",
    "breadcrumbs",
    "stack-trace"
  ],
  "author": {
    "name": "RiviumTrace Team",
    "email": "support@rivium.co",
    "url": "https://rivium.co"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rivium-co/rivium-trace-nodejs-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Rivium-co/rivium-trace-nodejs-sdk/issues"
  },
  "homepage": "https://rivium.co/cloud/rivium-trace",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "jsdoc": "^4.0.0",
    "supertest": "^6.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "lib/**/*.js",
      "index.js",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "off",
      "no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_"
        }
      ]
    }
  }
}
